# ============================================================
# Just Autos Portal — Environment Variables
# Copy this to .env.local for local dev
# Add all of these in Vercel → Project → Settings → Environment Variables
# ============================================================

# CData Connect Cloud — get from https://cloud.cdata.com → API → Credentials
CDATA_BASE_URL=https://cloud.cdata.com/api/odata4
CDATA_USERNAME=your_cdata_username
CDATA_PAT=your_cdata_personal_access_token

# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Portal access password (simple shared password for the team)
PORTAL_PASSWORD=your_secure_password_here

# Live call monitoring — in-browser softphone (WebRTC)
# WSS endpoint of FreePBX's chan_pjsip WebRTC transport. Public to the browser
# (it's just the URL — the per-user SIP password lives in user_profiles).
# Leave both unset to disable "Listen on Device" portal-wide.
NEXT_PUBLIC_FREEPBX_WSS_URL=wss://pbx.example.com:8089/ws
NEXT_PUBLIC_FREEPBX_SIP_DOMAIN=pbx.example.com
