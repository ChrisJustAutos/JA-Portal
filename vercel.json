{
  "name": "ja-management-portal",
  "framework": "nextjs",
  "functions": {
    "pages/api/dashboard.ts":                       { "maxDuration": 60 },
    "pages/api/distributors.ts":                    { "maxDuration": 60 },
    "pages/api/distributors/refresh-cache.ts":      { "maxDuration": 300 },
    "pages/api/chat.ts":                            { "maxDuration": 60 },
    "pages/api/test.ts":                            { "maxDuration": 60 },
    "pages/api/cron/sync-followups.ts":             { "maxDuration": 300 },
    "pages/api/cron/health-check.ts":               { "maxDuration": 60 },
    "pages/api/calls/backfill-followups.ts":        { "maxDuration": 300 },
    "pages/api/webhooks/graph-mail.ts":             { "maxDuration": 60 },
    "pages/api/admin/setup-graph-subscriptions.ts": { "maxDuration": 60 },
    "pages/api/cron/renew-graph-subscriptions.ts":  { "maxDuration": 60 },
    "pages/api/cron/bank-payments-slack.ts":        { "maxDuration": 120 },
    "pages/api/stripe-myob/list.ts":                { "maxDuration": 60 },
    "pages/api/stripe-myob/push.ts":                { "maxDuration": 120 },
    "pages/api/stripe-myob/sync.ts":                { "maxDuration": 300 },
    "pages/api/stripe-myob/payouts.ts":             { "maxDuration": 60 },
    "pages/api/stripe-myob/payouts-reconcile.ts":   { "maxDuration": 300 },
    "pages/api/stripe-myob/payouts-sync.ts":        { "maxDuration": 300 },
    "pages/api/stripe-myob/payouts-mark.ts":        { "maxDuration": 30 },
    "pages/api/admin/inspect-jaws-invoices.ts":     { "maxDuration": 60 },
    "pages/api/admin/inspect-jaws-account.ts":      { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/distributors/refresh-cache",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/sync-followups",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/renew-graph-subscriptions",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/bank-payments-slack",
      "schedule": "0 20,21 * * *"
    }
  ]
}
