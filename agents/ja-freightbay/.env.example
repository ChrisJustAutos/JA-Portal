# ja-freightbay — copy to .env and fill. See README.md §Connections.

# ── NVR (Hikvision ISAPI) ──
NVR_HOST=192.168.0.199
NVR_PORT=80
NVR_USER=
NVR_PASS=
# Freight Bay = D24 → channelID 2401 (D-number*100+1). Confirm with `npm run probe`.
NVR_CHANNEL_ID=2401

# ── Asterisk / Yealink ──
# The dedicated freight-bay handset's extension.
ALERT_EXTENSION=
ALERT_CALLERID=Freight Bay <8000>
DIALPLAN_CONTEXT=freight-bay-alert
ASTERISK_SPOOL_DIR=/var/spool/asterisk/outgoing
# Ring ONCE: one attempt, no retries. WaitTime = seconds it rings before giving
# up if unanswered. Bump CALL_MAX_RETRIES only if you want it to ring again.
CALL_MAX_RETRIES=0
CALL_RETRY_TIME=30
CALL_WAIT_TIME=25

# ── Slack (bot token, unattended) ──
# Scopes: chat:write, files:write. Channel ID (C…) from channel details.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Business-hours gate + debounce ──
BUSINESS_TZ=Australia/Perth
# Days of week that count (0=Sun … 6=Sat). Default Mon–Fri.
BUSINESS_DAYS=1,2,3,4,5
BUSINESS_START=07:00
BUSINESS_END=17:00
# One alert per this window (ms) so a single delivery doesn't ring repeatedly.
COOLDOWN_MS=120000

# Event types that count (Hikvision): line crossing + intrusion.
EVENT_TYPES=linedetection,fielddetection
# Some NVR firmwares drop the alertStream after a few seconds — keep this SHORT
# (400ms) or events fall into the reconnect gaps.
RECONNECT_MS=400

# ── Slack photo burst ──
# The service snapshots continuously (business hours) into a ring buffer —
# the NVR's snapshot endpoint lags live by ~3s, so post-event-only capture
# misses quick visitors. The burst posts up to BURST_COUNT frames spanning
# [event - PREROLL, event + POSTROLL] as one photo set under the text alert.
# NOTE the snapshot lag (~3s behind live on this NVR) when tuning: a frame
# captured at event+11s shows the scene at event+8s. These values give scene
# coverage of roughly [entry-4s .. exit+5s] on a quick visit.
BURST_COUNT=8
BURST_INTERVAL_MS=800
BURST_PREROLL_MS=2000
BURST_POSTROLL_MS=11000

# ── How events arrive ──
# PUSH: the camera/NVR Alarm Server POSTs events to this listener (reliable —
# use this if the pull-stream keeps dropping). Point the camera's Alarm Server
# at http://<this-host-ip>:8098.
USE_ALARM_SERVER=true
LISTEN_PORT=8098
# PULL: subscribe to the NVR alertStream. Set false on NVRs that drop it every
# few seconds (silences the reconnect churn) once push is working.
USE_ALERTSTREAM=true
