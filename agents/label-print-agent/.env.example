# Copy to .env and fill in. Runs on the workshop PC attached to the DYMO.
# The SERVICE ROLE key is sensitive — keep this file off any shared/synced drive.

SUPABASE_URL=https://qtiscbvhlvdvafwtdtcd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Exact Windows printer name (Settings → Printers, or run `node -e "require('pdf-to-printer').getPrinters().then(console.log)"`)
DYMO_PRINTER_NAME=DYMO LabelWriter 4XL

# A4 printer for the MYOB tax invoice (kind='invoice' jobs). Leave blank to use
# the Windows default printer. Use the exact printer name as above.
INVOICE_PRINTER_NAME=
INVOICE_SCALE=fit

# Optional overrides
LABEL_BUCKET=b2b-shipping-labels
POLL_MS=30000
MAX_ATTEMPTS=3
# 'fit' scales the 4x6 MachShip PDF to the label; use 'noscale' if your labels print correctly 1:1
PRINT_SCALE=fit
